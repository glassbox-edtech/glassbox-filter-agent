{
  "manifest_version": 3,
  "name": "Glassbox Filter Agent",
  "version": "1.1.5",
  "description": "Privacy-first, zero-knowledge educational network filter.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "unlimitedStorage",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["block.html", "config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
